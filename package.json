{
  "name": "feature-flag-engine-assessment",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,blue \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
